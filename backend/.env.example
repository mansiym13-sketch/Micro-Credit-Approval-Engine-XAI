# ─── Server ──────────────────────────────────────────────
PORT=5000

# ─── MySQL Database ──────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=loan_approval_engine
DB_PORT=3306

# ─── Explainable AI (XAI) Service ────────────────────────
# Local LLM served via Ollama (https://ollama.com). Install Ollama, then
# run `ollama pull llama3.1` (or any chat-capable model) before starting
# the backend. Applicant data never leaves this machine.
#
# If Ollama is not installed / not running, the XAI layer automatically
# falls back to a deterministic, rule-based natural-language explanation
# generator — the API and PDF report will always return an explanation.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
AI_EXPLANATION_TIMEOUT_MS=8000
